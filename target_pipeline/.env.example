# Same Postgres URL as Mining OS (postgresql+psycopg://user:pass@host:port/dbname)
DATABASE_URL=postgresql+psycopg://miningos:miningos@localhost:5432/miningos

# Comma-separated 2-letter state codes (default: UT,ID,WY,NV,AZ,MT). Overrides critical-minerals scope.
# TARGET_PIPELINE_STATES=UT,ID,WY,NV,AZ,MT

LOG_LEVEL=INFO

# Root folder for raw exports (optional subfolders mlrs/, usgs/)
TARGET_PIPELINE_DATA_DIR=./target_pipeline/data

# Where to write targets: areas_of_focus (Mining OS app) or standalone targets table
OUTPUT_TABLE=areas_of_focus

# If true and OUTPUT_TABLE=areas_of_focus, collapse (plss, commodity) groups to one row per PLSS
MERGE_BY_PLSS_FOR_APP=true

# Optional GeoJSON (polygons) with property plss or trs — fills PLSS when lat/lon present but text missing
# PLSS_LOOKUP_GEOJSON=

# Set to true to validate pipeline without writing the database
# TARGET_PIPELINE_DRY_RUN=false

# Optional: cap rows per source folder (MLRS total, USGS total) — use for huge national CSVs
# TARGET_PIPELINE_MAX_ROWS=50000

# Optional: tag this import batch (stored in characteristics; use cleanup --run-id to delete only this batch)
# TARGET_PIPELINE_RUN_ID=2026-04-02-batch1
