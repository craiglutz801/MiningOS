# Copy to .env and edit if needed

POSTGRES_USER=miningos
POSTGRES_PASSWORD=miningos
POSTGRES_DB=miningos
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

PGADMIN_EMAIL=admin@local.test
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# API / Dashboard
API_HOST=127.0.0.1
API_PORT=8000
DASHBOARD_PORT=8501

# States of focus (Utah, Idaho, Nevada, Montana, Wyoming)
TARGET_STATES=UT,ID,NV,MT,WY

# Minerals/commodities of interest (for scoring and alerts)
COMMODITIES=tungsten,scandium,beryllium,uranium,fluorspar,fluorite,germanium

# Spatial knobs
MRDS_RADIUS_KM=10

# Alerts: email for high-priority unpaid claims
ALERT_EMAIL=craiglutz801@gmail.com

# Optional: SMTP for sending alerts (Gmail: use App Password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your_app_password

# Optional: OpenAI (required for PDF / batch report AI extraction, and PLSS AI lookup)
# OPENAI_API_KEY=

# Optional: Gemini — second pass to extract PLSS from long web/Gemini-style blurbs (Find PLSS with AI)
# GEMINI_API_KEY=

# Fetch Claim Records: omit or 0 for fast BLM ArcGIS-only behavior (same as production).
# Set to 1 only if ../BLM_ClaimAgent exists and you want slow per-claim Selenium payment scrape.
# MINING_OS_FETCH_CLAIM_RECORDS_USE_AGENT=

# After ArcGIS returns claims we load each MLRS case page to detect the red maintenance-fee banner.
# HTTP is always tried first. The MLRS case page is a Salesforce Lightning SPA, so a real headless
# browser (Playwright preferred, Selenium fallback) is needed to see the banner reliably.
# Default: headless browser ON locally, OFF on Render/Railway.
# MINING_OS_MLRS_PAYMENT_HEADLESS=0   # never use a headless browser
# MINING_OS_MLRS_PAYMENT_HEADLESS=1   # always use it (e.g. force on prod after installing chromium)
#
# Local install for Playwright:
#   pip install -r requirements.txt
#   python -m playwright install chromium
#
# Production (Render/Railway): the blueprint installs Chromium during build and sets
# MINING_OS_MLRS_PAYMENT_HEADLESS=1 — same behavior as localhost after the two commands above.
# Hit GET /api/diag/environment and check ``mlrs_payment`` plus
# GET /api/diag/check-payment?case_url=https://mlrs.blm.gov/s/blm-case/...
#
# Prefer Selenium (ChromeDriver) before Playwright for each claim — optional.
# MINING_OS_MLRS_PAYMENT_PREFER_SELENIUM=1
# Cap SPA poll duration per claim (default 30000 ms) so Fetch Claim Records finishes faster:
# MINING_OS_MLRS_PLAYWRIGHT_MAX_MS=30000
# Run a few claim-page checks in parallel (default 3 locally, 1 on Render, max 4):
# MINING_OS_MLRS_PARALLELISM=3
# Reuse paid/unpaid results from recent fetches (default 24 hours):
# MINING_OS_MLRS_PAYMENT_CACHE_TTL_HOURS=24

# Batch Process Reports (USGS DS-1004 docket PDFs)
# Install: pip install -e ".[pdf-ocr]" and system Tesseract (brew install tesseract on macOS)
# BATCH_MAX_PDF_MB=150
# BATCH_OCR_MAX_PAGES=12
# BATCH_OCR_PAGE_TIMEOUT_SEC=120
# TESSERACT_CMD=/opt/homebrew/bin/tesseract
# Quick binary check (no Python OCR import): .venv/bin/python scripts/verify_tesseract.py
